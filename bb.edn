{:tasks
 {clj-repl
  {:doc "Start a Clojure REPL for this project"
   :task (shell "clj")}

  smoke
  {:doc "Require all project namespaces (quick compile/sanity check)"
   :task (shell "clj" "-M" "-e"
                "(require 'event-sourcing.account 'event-sourcing.decider 'event-sourcing.store 'event-sourcing.projection 'event-sourcing.infra 'user)")}

  lint
  {:doc "Run clj-kondo on source, dev, and test namespaces"
   :task (shell "clj-kondo --lint src dev test")}

  fmt-check
  {:doc "Check Clojure formatting with cljfmt"
   :task (shell "cljfmt check src dev test")}

  fmt
  {:doc "Format Clojure files in place with cljfmt"
   :task (shell "cljfmt fix src dev test")}

  test
  {:doc "Run unit + functional + integration tests (DB-backed tests require Docker/Testcontainers)"
   :task (shell "clj" "-M:test" "-e"
                "(require '[clojure.test :refer [run-tests]] 'event-sourcing.integration-test 'event-sourcing.store-integration-test 'event-sourcing.functional-test 'event-sourcing.account-test 'event-sourcing.decider-test 'event-sourcing.store-test 'event-sourcing.fuzz-unit-test 'event-sourcing.fuzz-integration-test 'event-sourcing.perf-check-test 'event-sourcing.perf-baseline-test 'event-sourcing.migrations-test 'event-sourcing.migrations-cli-test) (let [r (run-tests 'event-sourcing.integration-test 'event-sourcing.store-integration-test 'event-sourcing.functional-test 'event-sourcing.account-test 'event-sourcing.decider-test 'event-sourcing.store-test 'event-sourcing.fuzz-unit-test 'event-sourcing.fuzz-integration-test 'event-sourcing.perf-check-test 'event-sourcing.perf-baseline-test 'event-sourcing.migrations-test 'event-sourcing.migrations-cli-test)] (System/exit (if (and (zero? (:fail r)) (zero? (:error r))) 0 1)))")}

  fuzz
  {:doc "Run fuzz/property tests only"
   :task (shell "clj" "-M:test" "-e"
                "(require '[clojure.test :refer [run-tests]] 'event-sourcing.fuzz-unit-test 'event-sourcing.fuzz-integration-test) (let [r (run-tests 'event-sourcing.fuzz-unit-test 'event-sourcing.fuzz-integration-test)] (System/exit (if (and (zero? (:fail r)) (zero? (:error r))) 0 1)))")}

  perf
  {:doc "Run deterministic performance benchmarks and write target/perf results"
   :task (shell "clj" "-M:test" "-m" "event-sourcing.perf")}

  perf-check
  {:doc "Fail when perf metrics regress beyond configured threshold vs perf/baseline.edn"
   :depends [perf]
   :task (shell "clj" "-M:test" "-m" "event-sourcing.perf-check")}

  perf-baseline
  {:doc "Update perf/baseline.edn from the latest target/perf/results.edn"
   :task (shell "clj" "-M:test" "-m" "event-sourcing.perf-baseline")}

  migrate
  {:doc "Apply pending DB migrations (requires JDBC_URL, optional DB_USER/DB_PASSWORD)"
   :task (shell "clj" "-M" "-m" "event-sourcing.migrations-cli" "migrate")}

  rollback
  {:doc "Rollback the latest DB migration (requires JDBC_URL, optional DB_USER/DB_PASSWORD)"
   :task (shell "clj" "-M" "-m" "event-sourcing.migrations-cli" "rollback")}

  migration-status
  {:doc "Show completed and pending DB migrations (requires JDBC_URL, optional DB_USER/DB_PASSWORD)"
   :task (shell "clj" "-M" "-m" "event-sourcing.migrations-cli" "status")}

  coverage
  {:doc "Generate coverage report (DB-backed tests require Docker/Testcontainers)"
   :task (shell "clj" "-M:test:coverage" "-m" "cloverage.coverage"
                "--src-ns-path" "src"
                "--test-ns-path" "test"
                "--ns-regex" "event-sourcing.*"
                "--fail-threshold" "88"
                "--output" "target/coverage"
                "--codecov")}

  check
  {:doc "Run quick project checks (lint + format + smoke)"
   :depends [lint fmt-check smoke]}

  clean
  {:doc "Remove common local build/cache artifacts"
   :task (shell "rm -rf .cpcache target .bb .clj-kondo/.cache")}}}
