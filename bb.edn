{:tasks
 {clj-repl
  {:doc "Start a Clojure REPL for this project"
   :task (shell "clj")}

  smoke
  {:doc "Require all src + dev namespaces (quick compile/sanity check)"
   :task (shell "clj" "-M:dev" "-e"
                "(run! require (mapcat (fn [d] (->> (file-seq (clojure.java.io/file d)) (filter #(.endsWith (.getName %) \".clj\")) (map #(-> (.getPath %) (clojure.string/replace d \"\") (subs 1) (clojure.string/replace \"/\" \".\") (clojure.string/replace \"_\" \"-\") (clojure.string/replace \".clj\" \"\") symbol)))) [\"src\" \"dev\"]))")}

  lint
  {:doc "Run clj-kondo on source, dev, and test namespaces"
   :task (shell "clj-kondo --lint src dev test")}

  fmt-check
  {:doc "Check Clojure formatting with cljfmt"
   :task (shell "cljfmt check src dev test")}

  fmt
  {:doc "Format Clojure files in place with cljfmt"
   :task (shell "cljfmt fix src dev test")}

  test
  {:doc "Run all tests — auto-discovers *_test namespaces (DB-backed tests require Docker)"
   :task (shell "clj" "-X:test")}

  fuzz
  {:doc "Run fuzz/property tests only"
   :task (shell "clj" "-X:test" ":patterns" "[\".*fuzz.*\"]")}

  perf
  {:doc "Run deterministic performance benchmarks and write target/perf results"
   :task (shell "clj" "-M:test" "-m" "bank.perf")}

  perf-check
  {:doc "Fail when perf metrics regress beyond configured threshold vs perf/baseline.edn"
   :depends [perf]
   :task (shell "clj" "-M:test" "-m" "bank.perf-check")}

  perf-baseline
  {:doc "Update perf/baseline.edn from the latest target/perf/results.edn"
   :task (shell "clj" "-M:test" "-m" "bank.perf-baseline")}

  migrate
  {:doc "Apply pending event store migrations (requires JDBC_URL, optional DB_USER/DB_PASSWORD)"
   :task (shell "clj" "-M" "-m" "es.migrations-cli" "migrate")}

  migrate-read
  {:doc "Apply pending read store migrations (requires JDBC_URL pointing to read DB)"
   :task (shell "clj" "-M" "-m" "es.migrations-cli" "migrate" "read-migrations")}

  migrate-notification
  {:doc "Apply pending notification DB migrations (requires JDBC_URL pointing to notification DB)"
   :task (shell "clj" "-M" "-m" "es.migrations-cli" "migrate" "notification-migrations")}

  rollback
  {:doc "Rollback the latest event store migration (requires JDBC_URL, optional DB_USER/DB_PASSWORD)"
   :task (shell "clj" "-M" "-m" "es.migrations-cli" "rollback")}

  migration-status
  {:doc "Show completed and pending DB migrations (requires JDBC_URL, optional DB_USER/DB_PASSWORD)"
   :task (shell "clj" "-M" "-m" "es.migrations-cli" "status")}

  coverage
  {:doc "Generate coverage report (DB-backed tests require Docker/Testcontainers)"
   :task (shell "clj" "-M:test:coverage" "-m" "cloverage.coverage"
                "--src-ns-path" "src"
                "--test-ns-path" "test"
                "--ns-regex" "(es|bank).*"
                "--fail-threshold" "88"
                "--output" "target/coverage"
                "--codecov")}

  check
  {:doc "Run quick project checks (lint + format + smoke)"
   :depends [lint fmt-check smoke]}

  clean
  {:doc "Remove common local build/cache artifacts"
   :task (shell "rm -rf .cpcache target .bb .clj-kondo/.cache")}}}
